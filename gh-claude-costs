#!/usr/bin/env bash
# gh-claude-costs: GitHub CLI extension to view Claude Code usage costs
# Install: gh extension install <repo>
# Usage:   gh claude-costs [--since YYYY-MM-DD]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
EXTRACT="$SCRIPT_DIR/extract.py"
TEMPLATE="$SCRIPT_DIR/template.html"

if ! command -v python3 &>/dev/null; then
  echo "Error: python3 is required but not found" >&2
  exit 1
fi

# Extract data, inject into template, open
python3 - "$EXTRACT" "$TEMPLATE" "$@" <<'PYEOF'
import subprocess, sys, os, tempfile, json, http.server, threading, socket, webbrowser

extract_script = sys.argv[1]
template_path = sys.argv[2]
extra_args = sys.argv[3:]

# Run extract.py
result = subprocess.run(
    ["python3", extract_script] + extra_args,
    capture_output=True, text=True
)
if result.returncode != 0:
    print(result.stderr, file=sys.stderr)
    sys.exit(1)
print(result.stderr, end="", file=sys.stderr)

data_json = result.stdout.strip()

# Validate it's valid JSON
json.loads(data_json)

# Read template and inject
with open(template_path) as f:
    html = f.read()

html = html.replace("__INJECTED_DATA__", data_json)

# Serve via localhost to avoid file:// restrictions and file-association issues
content = html.encode("utf-8")
served = threading.Event()

class Handler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.end_headers()
        self.wfile.write(content)
        served.set()
    def log_message(self, *args):
        pass

sock = socket.socket()
sock.bind(("127.0.0.1", 0))
port = sock.getsockname()[1]
sock.close()

server = http.server.HTTPServer(("127.0.0.1", port), Handler)
threading.Thread(target=server.serve_forever, daemon=True).start()
print(f"Dashboard: http://127.0.0.1:{port}", file=sys.stderr)
webbrowser.open(f"http://127.0.0.1:{port}")
served.wait(timeout=10)
server.shutdown()
PYEOF
